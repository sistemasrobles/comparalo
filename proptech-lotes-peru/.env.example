# =========================================
# PropTech Lotes Perú - Environment Config
# =========================================

# General
NODE_ENV=development
APP_NAME=PropTech Lotes Perú

# Database (PostgreSQL)
DATABASE_URL=postgresql://proptech:proptech123@localhost:5432/proptech_lotes?schema=public
POSTGRES_USER=proptech
POSTGRES_PASSWORD=proptech123
POSTGRES_DB=proptech_lotes

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend API
API_PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=change-this-to-a-very-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-also-32-chars-minimum
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ComparaLotes

# Maps (choose one)
NEXT_PUBLIC_MAP_PROVIDER=google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Google Analytics
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# File Storage (local or s3)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# S3-compatible (optional)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=proptech-lotes
S3_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Admin Default User (seed)
ADMIN_EMAIL=admin@comparalotes.pe
ADMIN_PASSWORD=Admin123!

# WhatsApp (for lead routing link generation)
WHATSAPP_DEFAULT_NUMBER=51999999999
